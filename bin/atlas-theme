#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
#  atlas-theme — unified theme switcher (omarchy-style, glass idiom)
#  Renders one palette (themes/<name>/colors.sh) into every app's
#  theme file, then reloads each app live.
#
#    atlas-theme set <name>   apply a theme
#    atlas-theme list         list available themes
#    atlas-theme get          print the current theme
#    atlas-theme toggle       swap cobalt <-> cobalt-light (dark/light)
#    atlas-theme              rofi picker
# ═══════════════════════════════════════════════════════════════
set -uo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}")"
REPO="$(dirname "$(dirname "$SELF")")"
THEMES_DIR="$REPO/themes"
STATE="$HOME/.local/state/atlas"; mkdir -p "$STATE"
CUR_FILE="$STATE/current-theme"
LOCK="${XDG_RUNTIME_DIR:-/tmp}/atlas-theme.lock"
C="$HOME/.config"

list()  { find "$THEMES_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort; }
get()   { [ -f "$CUR_FILE" ] && cat "$CUR_FILE" || echo "cobalt"; }
die()   { echo "atlas-theme: $*" >&2; exit 1; }

render() {
  local name="$1" dir="$THEMES_DIR/$1"
  [ -f "$dir/colors.sh" ] || die "no such theme: $name"
  # shellcheck disable=SC1090
  source "$dir/colors.sh"

  # ── waybar (GTK CSS named colors) ──
  mkdir -p "$C/waybar"
  # Material densities, composed here rather than in the stylesheet.
  #
  # GTK CSS can do alpha(@colour, 0.55) but the 0.55 cannot itself be a
  # variable, so a static stylesheet cannot vary density by mode -- and it has
  # to. A 55% DARK bar over any wallpaper still reads dark and its text stays
  # legible; a 55% LIGHT bar turns into a pale wash and mid-grey chip text
  # disappears into it. Same failure as the launcher, one layer up.
  #
  # Light therefore runs much denser, exactly as macOS light materials do.
  # mat-thin  = waybar   (chrome over content, the most transparent layer)
  # mat-tint  = chips and other elements INSIDE a material -- a wash that
  #             composites against the panel, never a second alpha over the
  #             desktop, which would multiply and go murky.
  local mat_thin mat_popover mat_tint mat_tint_hi
  if [ "${MODE:-dark}" = "light" ]; then
    mat_thin="rgba(255,255,255,0.88)"; mat_popover="rgba(255,255,255,0.94)"
    mat_tint="rgba(0,0,0,0.055)";      mat_tint_hi="rgba(0,0,0,0.11)"
  else
    mat_thin="rgba(15,18,24,0.40)";    mat_popover="rgba(15,18,24,0.62)"
    mat_tint="rgba(255,255,255,0.07)"; mat_tint_hi="rgba(255,255,255,0.14)"
  fi

  cat > "$C/waybar/theme.css" <<EOF
@define-color base #$BASE;
@define-color surface #$SURFACE;
@define-color surface2 #$SURFACE2;
@define-color text #$TEXT;
@define-color subtext #$SUBTEXT;
@define-color accent #$ACCENT;
@define-color good #$T2;
@define-color warn #$T3;
@define-color crit #$T1;
@define-color border $BORDER;

/* materials — density varies by mode, see bin/atlas-theme */
@define-color mat-thin $mat_thin;
@define-color mat-popover $mat_popover;
@define-color mat-tint $mat_tint;
@define-color mat-tint-hi $mat_tint_hi;
EOF
  # swaync reuses the waybar palette
  mkdir -p "$C/swaync"; cp "$C/waybar/theme.css" "$C/swaync/theme.css" 2>/dev/null || true

  # ── alacritty ──
  mkdir -p "$C/alacritty"
  cat > "$C/alacritty/theme.toml" <<EOF
[colors.primary]
background = "#$BASE"
foreground = "#$TEXT"
[colors.cursor]
cursor = "#$CURSOR"
text = "#$BASE"
[colors.normal]
black = "#$T0"
red = "#$T1"
green = "#$T2"
yellow = "#$T3"
blue = "#$T4"
magenta = "#$T5"
cyan = "#$T6"
white = "#$T7"
[colors.bright]
black = "#$T8"
red = "#$T9"
green = "#$T10"
yellow = "#$T11"
blue = "#$T12"
magenta = "#$T13"
cyan = "#$T14"
white = "#$T15"
EOF

  # ── ghostty ──
  mkdir -p "$C/ghostty"
  {
    echo "background = #$BASE"
    echo "foreground = #$TEXT"
    echo "cursor-color = #$CURSOR"
    echo "selection-background = #$SURFACE2"
    echo "selection-foreground = #$TEXT"
    local i vars=(T0 T1 T2 T3 T4 T5 T6 T7 T8 T9 T10 T11 T12 T13 T14 T15)
    for i in "${!vars[@]}"; do echo "palette = $i=#${!vars[$i]}"; done
  } > "$C/ghostty/theme.conf"

  # ── rofi ──
  # The -glass variants carry their alpha in the colour itself. rasi has no
  # alpha()/rgba-mix function, so a translucent surface cannot be composed in
  # the stylesheet the way waybar's GTK CSS does it -- it has to be emitted
  # here, per theme.
  #
  # The alpha values are deliberately moderate (a8 = 66%, b3 = 70%). mango
  # runs scenefx blur behind these, and the readable result comes from a high
  # blur radius at moderate opacity, not from a low opacity at low radius --
  # which is the correction Apple spent the whole iOS 26 beta cycle making
  # after Liquid Glass menus turned illegible over bright backgrounds.
  # Glass has to be mode-aware, and this is not cosmetic.
  #
  # A dark surface at 66% over a bright wallpaper still reads dark, because the
  # dark base wins the blend. A LIGHT surface at 66% over that same wallpaper
  # does not -- it turns into a bright wash with near-white text on it, which
  # is illegible. Emitting one alpha for both modes made cobalt-light unusable
  # the moment the launcher went translucent.
  #
  # So light themes get a much higher opacity (e6/f2 vs a8/b3) and DARK
  # hairlines. This mirrors how macOS handles it: light materials are far more
  # opaque than dark ones and separate themselves with a subtle dark divider
  # rather than a lit edge, because a white specular edge is invisible on white.
  #
  # bar_tint is the other half of this. An element INSIDE a translucent panel
  # must not carry its own alpha over the wallpaper -- the two layers multiply
  # and the inner one turns murky and darker than either. Apple is explicit
  # that stacking materials looks wrong. So inner surfaces are a TINT: a wash
  # of white (dark mode) or black (light mode) that lightens or darkens the
  # material already there, compositing against the panel rather than the
  # desktop behind it.
  local bg_a bar_a sel_a hair hair_lit bar_tint
  if [ "${MODE:-dark}" = "light" ]; then
    bg_a=e6; bar_a=f2; sel_a=2e; hair="#0000001a"; hair_lit="#00000026"
    bar_tint="#00000012"
  else
    bg_a=73; bar_a=8c; sel_a=4d; hair="#ffffff1a"; hair_lit="#ffffff33"
    bar_tint="#ffffff14"
  fi

  mkdir -p "$C/rofi"
  cat > "$C/rofi/theme.rasi" <<EOF
* {
    bg:       #$BASE;
    bg-alt:   #$SURFACE;
    fg:       #$TEXT;
    fg-alt:   #$SUBTEXT;
    accent:   #$ACCENT;
    urgent:   #$T1;

    /* glass surfaces — alpha differs by mode, see bin/atlas-theme */
    bg-glass:   #${BASE}${bg_a};
    bar-glass:  #${SURFACE}${bar_a};
    sel-glass:  #${ACCENT}${sel_a};
    bar-tint:   ${bar_tint};
    hair:       ${hair};
    hair-lit:   ${hair_lit};
}
EOF

  # ── mango (window borders, sourced by config.conf) ──
  mkdir -p "$C/mango"
  cat > "$C/mango/theme.conf" <<EOF
rootcolor=0x${GROUND}ff
bordercolor=0x${SURFACE2}ff
focuscolor=0x${ACCENT}ff
urgentcolor=0x${T1}ff
dropcolor=0x${T2}55
splitcolor=0x${T1}ff
maximizescreencolor=0x${T3}ff
scratchpadcolor=0x${T5}ff
globalcolor=0x${T6}ff
overlaycolor=0x${T2}ff
EOF

  # ── swaylock (themed lock screen) ──
  mkdir -p "$C/swaylock"
  cat > "$C/swaylock/config" <<EOF
color=$BASE
inside-color=$SURFACE
inside-ver-color=$ACCENT
inside-wrong-color=$T1
ring-color=$SURFACE2
ring-ver-color=$ACCENT
ring-wrong-color=$T1
key-hl-color=$ACCENT
bs-hl-color=$T1
line-color=$BASE
separator-color=$BASE
text-color=$TEXT
text-ver-color=$TEXT
text-wrong-color=$TEXT
indicator-radius=90
indicator-thickness=8
font=JetBrainsMono Nerd Font
show-failed-attempts
EOF

  # ── neovim (tracked colourscheme + generated palette) ──
  # colors/atlas.lua derives every syntax role from these slots -- see
  # config/nvim/lua/atlas/roles.lua for the VS Code Dark+ mapping. Guarded on
  # the colourscheme existing rather than on the directory, so this never
  # conjures a half-populated ~/.config/nvim on a box without the editor config.
  #
  # Written tmp+rename: nvim watches this directory and re-sources on change,
  # so a partially-written file would flash a broken palette into a live editor.
  if [ -f "$C/nvim/colors/atlas.lua" ]; then
    local slot n ref
    mkdir -p "$C/nvim/lua/atlas"
    {
      echo "-- GENERATED by atlas-theme from themes/$name/colors.sh -- do not edit."
      echo "-- Colours: edit themes/$name/colors.sh. Mapping: edit colors/atlas.lua."
      echo "return {"
      echo "  NAME = \"$NAME\","
      echo "  MODE = \"$MODE\","
      for slot in GROUND BASE SURFACE SURFACE2 TEXT SUBTEXT ACCENT ACCENT_INK CURSOR; do
        echo "  $slot = \"${!slot}\","
      done
      for n in $(seq 0 15); do
        ref="T$n"
        echo "  T$n = \"${!ref}\","
      done
      echo "}"
    } > "$C/nvim/lua/atlas/palette.lua.tmp" \
      && mv "$C/nvim/lua/atlas/palette.lua.tmp" "$C/nvim/lua/atlas/palette.lua"
  fi

  # export for the wallpaper step
  # ── starship (tracked body + generated palette) ──
  # starship has no include mechanism, so the file is assembled here.
  # ORDER MATTERS: [palettes.atlas] is a TOML table, so everything after it
  # belongs to that table. The body's root keys (format, add_newline) must
  # come BEFORE it or starship silently ignores them and falls back to its
  # default prompt.
  if [ -f "$REPO/config/starship/body.toml" ]; then
    {
      echo "# GENERATED by atlas-theme from themes/$name/colors.sh — do not edit."
      echo "# Edit config/starship/body.toml (shape) or the theme's colors.sh (colours)."
      echo 'palette = "atlas"'
      echo
      cat "$REPO/config/starship/body.toml"
      cat <<EOF

# ── palette (generated from themes/$name/colors.sh) ────────────
# Keep this LAST: it is a TOML table.
[palettes.atlas]
accent     = "#$ACCENT"
accent_ink = "#$ACCENT_INK"
ink        = "#$GROUND"
base       = "#$BASE"
surface    = "#$SURFACE"
surface2   = "#$SURFACE2"
text       = "#$TEXT"
subtext    = "#$SUBTEXT"
err        = "#$T1"
EOF
    } > "$C/starship.toml.tmp" && mv "$C/starship.toml.tmp" "$C/starship.toml"
  fi

  APPLIED_GROUND="$GROUND"
}

reload() {
  # bar / notifications / terminals — best-effort, never fail the switch
  pkill -SIGUSR2 waybar   2>/dev/null || true
  pkill -USR2 ghostty     2>/dev/null || true   # ghostty reloads config on SIGUSR2
  swaync-client -rs       2>/dev/null || true   # reload swaync css
  # nvim needs nothing here: colors/atlas.lua watches lua/atlas/ and re-sources
  # itself when render() rewrites palette.lua. Signalling it would mean finding
  # every instance across every tmux pane; letting it watch is simpler and works
  # for editors started after the switch too.
  # Wallpaper: delegate. This used to kill swaybg and restart it with a flat
  # colour, throwing the image away on every theme switch.
  REPO="$REPO" "$REPO/bin/atlas-wallpaper" 2>/dev/null || true
  # mango reads window-border colours from theme.conf on config reload;
  # trigger it if mango exposes an IPC, else it applies on Super+Shift+R.
  command -v mangomsg >/dev/null 2>&1 && mangomsg reload 2>/dev/null || true
}

set_theme() {
  local name="$1"
  [ -d "$THEMES_DIR/$name" ] || die "unknown theme '$name' (try: atlas-theme list)"

  # The lock covers ONLY the file writing. It must not cover reload(), because
  # reload spawns long-lived children (swaybg) that INHERIT the lock file
  # descriptor and then hold the lock for as long as they run -- deadlocking
  # every later invocation. Scoping the lock to a subshell also guarantees the
  # fd is closed on exit even if render() fails.
  #
  # -w 5: never block forever. If something is genuinely wedged, say so and
  # exit rather than adding another stuck process to the pile.
  (
    flock -w 5 9 || { echo "atlas-theme: timed out waiting for the lock" >&2; exit 1; }
    render "$name"
    echo "$name" > "$CUR_FILE"
  ) 9>"$LOCK" || return 1

  reload                       # outside the lock, on purpose
  command -v notify-send >/dev/null 2>&1 && notify-send "Theme" "$name" -t 1500
  echo "→ $name"
}

pick() {
  command -v rofi >/dev/null 2>&1 || die "rofi not installed"
  local choice
  choice="$(list | rofi -dmenu -i -p "theme" -theme-str '* { width: 360px; }')" || exit 0
  [ -n "$choice" ] && set_theme "$choice"
}

case "${1:-pick}" in
  set)    shift; [ $# -ge 1 ] || die "usage: atlas-theme set <name>"; set_theme "$1" ;;
  list)   list ;;
  get|current) get ;;
  toggle) [ "$(get)" = "cobalt-light" ] && set_theme cobalt || set_theme cobalt-light ;;
  pick)   pick ;;
  -h|--help) sed -n '2,14p' "$SELF" | sed 's/^# \{0,1\}//' ;;
  *)      die "unknown command '$1' (set|list|get|toggle|pick)" ;;
esac
