#!/usr/bin/env bash
# Install ly and enable it as the login manager.
#
# Run as root:   doas bash bin/setup-ly
#
# WHY THIS ISN'T JUST `emerge x11-misc/ly`
# ----------------------------------------
# GURU's ly Manifest no longer matches what Codeberg serves. Codeberg builds
# archive tarballs on demand and the gzip output is not byte-reproducible, so:
#
#     Fetched file: ly-1.4.1.tar.gz VERIFY FAILED!
#     Reason: Filesize does not match recorded size
#     Got: 146988   Expected: 147223
#
# (The 404 portage prints first is only distfiles.gentoo.org, which does not
# mirror GURU distfiles. Upstream itself is fine — both GitHub and Codeberg
# return 200.) All three GURU versions are affected identically.
#
# The workaround is to re-digest the ebuild against what the server serves now.
# BE CLEAR ABOUT WHAT THAT COSTS: it replaces upstream's recorded hash with the
# hash of whatever you just downloaded, so the integrity check no longer proves
# anything about the contents. It is also wiped by `emerge --sync guru`, so it
# has to be redone after each sync. This is a GURU packaging bug worth filing
# rather than carrying forever.
set -euo pipefail
[ "$(id -u)" -eq 0 ] || { echo "run as root: doas bash bin/setup-ly"; exit 1; }
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

EBUILD=/var/db/repos/guru/x11-misc/ly/ly-1.4.1.ebuild
[ -f "$EBUILD" ] || { echo "no ly ebuild at $EBUILD — is GURU synced?"; exit 1; }

echo "==> keywording ly"
# The keyword lives in the tracked system/portage file, so appending here would
# make /etc permanently disagree with the repo. Deploy the tracked copy instead.
install -D -m 0644 "$REPO_DIR/system/portage/package.accept_keywords/atlas" \
                   /etc/portage/package.accept_keywords/atlas

echo "==> clearing the failed download"
# A previous attempt leaves the rejected tarball as
# /var/cache/distfiles/ly-<v>.tar.gz._checksum_failure_.XXXX. While that is
# present, `ebuild ... manifest` will not re-fetch, so the digest never
# changes and the next emerge fails exactly the same way.
rm -f /var/cache/distfiles/ly-*.tar.gz._checksum_failure_.* \
      /var/cache/distfiles/ly-*.tar.gz.__download__ 2>/dev/null || true

echo "==> re-digesting the ebuild (see the note at the top of this file)"
# --force is required: without it portage keeps the existing Manifest entries
# and the size/hash mismatch survives.
if ! ebuild --force "$EBUILD" manifest; then
    echo
    echo "  re-digest FAILED. ly was not installed and nothing was changed." >&2
    echo "  Log in on a TTY and run 'exec mango' if you need the desktop." >&2
    exit 1
fi
echo "  new recorded size: $(awk '/ly-1.4.1.tar.gz/{print $3}' \
    /var/db/repos/guru/x11-misc/ly/Manifest)"

echo "==> emerging ly"
emerge --noreplace --quiet x11-misc/ly

echo "==> installing config"
install -D -m 0644 "$REPO_DIR/system/ly/config.ini" /etc/ly/config.ini

echo "==> enabling ly"
rc-update add ly default


echo "==> resolving the tty2 conflict"
# ly's init script hardcodes TTY="tty2" and runs `agetty -nl /usr/bin/ly tty2`.
# Gentoo's /etc/inittab ALSO respawns a plain agetty on tty2 (line c2), so both
# fight for the same terminal and the greeter flickers or respawn-loops.
# Comment out c2 only. c1 and c3-c6 stay, which is the recovery path: if ly
# fails to come up, Ctrl+Alt+F1 still gives a console.
if grep -qE '^c2:2345:respawn:.*tty2' /etc/inittab; then
    cp /etc/inittab /etc/inittab.bak.$(date +%Y%m%d-%H%M%S)
    sed -i '/^c2:2345:respawn:.*tty2/s/^/#/' /etc/inittab
    echo "  commented out the tty2 getty in /etc/inittab"
else
    echo "  tty2 getty already disabled"
fi

echo "==> verifying"
command -v ly >/dev/null && echo "  ly binary:   $(command -v ly)" || { echo "  ly MISSING"; exit 1; }
[ -f /etc/init.d/ly ] && echo "  init script: present" || { echo "  init script MISSING"; exit 1; }
rc-update show default | grep -qw ly && echo "  runlevel:    default" || echo "  NOT in default runlevel"
grep -q "^waylandsessions = /usr/share/wayland-sessions" /etc/ly/config.ini \
  && echo "  sessions:    /usr/share/wayland-sessions ($(ls /usr/share/wayland-sessions | tr '\n' ' '))"

cat <<'NOTE'

  ly is enabled but NOT started -- it takes over a VT, and starting it from an
  SSH session would be a good way to lose the console you are sitting on.
  Reboot to use it.

  ly runs on tty2. If it fails to come up, Ctrl+Alt+F1 still gives a console
  (c1 in /etc/inittab is untouched), and `exec mango` starts the desktop
  directly — a TTY login is the fallback.
NOTE
