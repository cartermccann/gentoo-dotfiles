#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
#  setup-limine — install the Limine bootloader alongside GRUB
#
#    doas bash bin/setup-limine            install + arm a one-shot test
#    doas bash bin/setup-limine --default  make Limine the default boot entry
#    doas bash bin/setup-limine --revert   remove Limine, leave GRUB alone
#
#  GRUB IS NOT TOUCHED. Not its EFI binary, not its NVRAM entry, not the
#  kernels in /boot that it boots from. Limine is added as a second, parallel
#  boot path; the default boot order only changes when you pass --default,
#  after you have seen it work.
#
#  The first run arms `efibootmgr --bootnext`, a ONE-SHOT boot. If Limine
#  fails, the very next reboot falls back to GRUB on its own, with nothing to
#  undo. That matters because atlas is normally reached over SSH: a bootloader
#  that fails with no fallback is the one change that needs someone standing
#  in front of the machine with a USB stick.
# ═══════════════════════════════════════════════════════════════
set -uo pipefail

ESP="${ESP:-/efi}"
REPO="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
HOOK_SRC="$REPO/system/kernel/postinst.d/95-limine.install"
HOOK_DST="/etc/kernel/postinst.d/95-limine.install"
LOADER='\EFI\Limine\BOOTX64.EFI'
LABEL="Limine"

c()   { printf '\033[1;34m▸\033[0m %s\n' "$*"; }
ok()  { printf '  \033[1;32m✓\033[0m %s\n' "$*"; }
warn(){ printf '  \033[1;33m!\033[0m %s\n' "$*"; }
die() { printf '  \033[1;31m✗\033[0m %s\n' "$*" >&2; exit 1; }

[ "$(id -u)" = 0 ] || die "run as root:  doas bash bin/setup-limine"

# ── Where is the ESP, really ───────────────────────────────────
esp_src="$(findmnt -no SOURCE "$ESP" 2>/dev/null)" || true
[ -n "$esp_src" ] || die "$ESP is not a mount point — is the ESP mounted?"
[ "$(findmnt -no FSTYPE "$ESP")" = vfat ] || die "$ESP is not vfat; Limine reads FAT only"
esp_disk="/dev/$(lsblk -no PKNAME "$esp_src")"
esp_part="$(cat "/sys/class/block/$(basename "$esp_src")/partition")"

revert() {
    c "removing Limine"
    for n in $(efibootmgr | sed -n "s/^Boot\([0-9A-F]\{4\}\)\*\? $LABEL\$/\1/p"); do
        efibootmgr -b "$n" -B >/dev/null && ok "deleted NVRAM entry Boot$n"
    done
    rm -rf "$ESP/EFI/Limine" "$ESP/atlas" "$ESP/limine.conf" "$ESP/wallpaper.jpg"
    rm -f "$HOOK_DST" /etc/limine/palette.conf
    ok "ESP and hook cleaned; GRUB untouched"
    efibootmgr | grep -E "^(BootOrder|BootCurrent)"
    exit 0
}

set_default() {
    n="$(efibootmgr | sed -n "s/^Boot\([0-9A-F]\{4\}\)\*\? $LABEL\$/\1/p" | head -1)"
    [ -n "$n" ] || die "no $LABEL entry found — run without --default first"
    order="$(efibootmgr | sed -n 's/^BootOrder: //p')"
    neworder="$n,$(echo "$order" | sed "s/\b$n\b,\?//g" | sed 's/,$//')"
    efibootmgr -o "$neworder" >/dev/null && ok "BootOrder → $neworder"
    warn "GRUB stays in the list as the next entry; pick it from the firmware menu if needed"
    exit 0
}

case "${1:-}" in
    --revert)  revert ;;
    --default) set_default ;;
    "")        ;;
    *)         die "unknown option '$1' (--default | --revert)" ;;
esac

# ── 1. the loader ──────────────────────────────────────────────
c "installing the Limine EFI binary"
[ -f /usr/share/limine/BOOTX64.EFI ] || die "sys-boot/limine not installed (emerge sys-boot/limine)"
install -Dm644 /usr/share/limine/BOOTX64.EFI "$ESP/EFI/Limine/BOOTX64.EFI" \
    || die "could not write to $ESP — is it mounted read-write?"
ok "$ESP/EFI/Limine/BOOTX64.EFI"

# ── 2. wallpaper + palette from the active theme ───────────────
c "theme"
theme="$(cat /home/*/.local/state/atlas/current-theme 2>/dev/null | head -1)"
theme="${theme:-cobalt}"
colors="$REPO/themes/$theme/colors.sh"
if [ -r "$colors" ]; then
    # Re-export only the slots the hook consumes. Written to /etc so the hook
    # never has to read out of a user-writable checkout as root.
    # shellcheck disable=SC1090
    ( set -a; . "$colors"; set +a
      mkdir -p /etc/limine
      { echo "# GENERATED by bin/setup-limine from themes/$theme/colors.sh"
        echo "BASE=$GROUND"; echo "TEXT=$TEXT"; echo "ACCENT=$ACCENT"
        for i in $(seq 0 15); do v="T$i"; echo "T$i=${!v}"; done
      } > /etc/limine/palette.conf )
    ok "palette from theme '$theme' → /etc/limine/palette.conf"
else
    warn "theme '$theme' not found; the hook falls back to baked-in cobalt"
fi

wp="$(find "$REPO/config/mango/wallpaper" -maxdepth 1 -type f \
        \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' \) 2>/dev/null | sort | head -1)"
if [ -n "$wp" ]; then
    cp -f "$wp" "$ESP/wallpaper.jpg" && ok "wallpaper → $ESP/wallpaper.jpg ($(basename "$wp"))"
else
    warn "no wallpaper found; Limine will use a flat background"
fi

# ── 3. the kernel hook, then run it ────────────────────────────
c "kernel hook"
[ -f "$HOOK_SRC" ] || die "missing $HOOK_SRC"
install -Dm755 "$HOOK_SRC" "$HOOK_DST"
ok "$HOOK_DST"
# Record the cmdline the machine is actually running, so the hook does not have
# to guess on a later kernel install (when /proc/cmdline may already be stale).
if [ ! -r /etc/kernel/cmdline ]; then
    mkdir -p /etc/kernel
    sed 's/BOOT_IMAGE=[^ ]* *//' /proc/cmdline | sed 's/^ *//;s/ *$//' > /etc/kernel/cmdline
    ok "/etc/kernel/cmdline ← $(cat /etc/kernel/cmdline)"
fi
"$HOOK_DST" || die "hook failed"
[ -f "$ESP/limine.conf" ] || die "hook did not produce $ESP/limine.conf"

# ── 4. prune stale NVRAM entries ───────────────────────────────
# Evidence-based on purpose: an entry is removed only if the loader file it
# points at is genuinely absent from THIS ESP. Nothing is deleted on the
# strength of its name. Pass --prune-dry-run to see the verdicts and change
# nothing -- worth doing once, because efibootmgr -v output is awkward to
# parse (tabs, an optional '*' for active entries, two spaces when inactive)
# and this is the only step here that destroys anything.
prune_stale() {
    local dry="${1:-}" num label path unix_path
    while IFS= read -r line; do
        case "$line" in Boot[0-9A-F][0-9A-F][0-9A-F][0-9A-F]*) ;; *) continue ;; esac
        num="${line:4:4}"
        # strip "BootXXXX", then a leading '*' if the entry is active, then spaces
        label="${line:8}"; label="${label#\*}"; label="${label#"${label%%[![:space:]]*}"}"
        label="${label%%$'\t'*}"
        # only ever consider these three; everything else is left alone
        case "$label" in "Linux Boot Manager"|artix|Limine) ;; *) continue ;; esac
        path="$(printf '%s' "$line" | grep -oiE '\\EFI\\[^,)]*\.efi' | head -1)"
        [ -n "$path" ] || continue
        unix_path="$ESP/$(printf '%s' "$path" | tr '\\' '/' | sed 's|^/||')"
        if [ -f "$unix_path" ]; then
            [ -n "$dry" ] && echo "    KEEP   Boot$num $label -> $path (present)"
        elif [ -n "$dry" ]; then
            echo "    DELETE Boot$num $label -> $path (absent from $ESP)"
        else
            efibootmgr -b "$num" -B >/dev/null && ok "deleted Boot$num ($label) — $path absent from $ESP"
        fi
    done < <(efibootmgr -v)
}

if [ "${PRUNE_DRY_RUN:-0}" = 1 ]; then
    c "NVRAM prune — DRY RUN, nothing will be deleted"
    prune_stale dry
    exit 0
fi

c "pruning dead NVRAM entries"
prune_stale

# ── 5. NVRAM entry ─────────────────────────────────────────────
c "NVRAM entry"
if efibootmgr | grep -qE "^Boot[0-9A-F]{4}\*? $LABEL\$"; then
    ok "$LABEL entry already present"
else
    efibootmgr --create --disk "$esp_disk" --part "$esp_part" \
        --label "$LABEL" --loader "$LOADER" >/dev/null \
        || die "efibootmgr failed to create the entry"
    ok "created $LABEL → $esp_disk part $esp_part $LOADER"
fi

# ── 6. arm the one-shot test ───────────────────────────────────
n="$(efibootmgr | sed -n "s/^Boot\([0-9A-F]\{4\}\)\*\? $LABEL\$/\1/p" | head -1)"
efibootmgr -n "$n" >/dev/null && ok "BootNext → Boot$n (one-shot)"

cat <<EOF

  ╭──────────────────────────────────────────────────────────────╮
  │  Limine is installed but NOT the default.                    │
  ╰──────────────────────────────────────────────────────────────╯

  The next reboot boots Limine ONCE. If anything is wrong, just reboot
  again and the firmware goes straight back to GRUB — nothing to undo.

  If it boots clean:      doas bash bin/setup-limine --default
  If you want it gone:    doas bash bin/setup-limine --revert

  GRUB is untouched: $ESP/EFI/Gentoo/grubx64.efi and /boot on btrfs are
  exactly as they were.

EOF
efibootmgr | grep -E "^(BootNext|BootOrder|BootCurrent)"
