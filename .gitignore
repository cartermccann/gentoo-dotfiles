# backups the installer makes
*.bak
*.bak.*

# theme files generated into the config dirs by `atlas-theme`
# (source of truth is themes/*/colors.sh + the atlas-theme renderer)
config/waybar/theme.css
config/foot/theme.ini
config/alacritty/theme.toml
config/ghostty/theme.conf
config/rofi/theme.rasi
config/mango/theme.conf
config/mako/config
config/swaync/theme.css

# local wallpaper binaries (drop your own in config/mango/wallpaper/)
config/mango/wallpaper/*
!config/mango/wallpaper/.gitkeep

# fish runtime state — written by fish itself and by tool `init` snippets
# (atuin/opencode drop files here). ~/.config/fish symlinks INTO this repo,
# so without these every checkout goes dirty on first shell start.
config/fish/fish_variables
config/fish/conf.d/

# editor / os cruft
.DS_Store
*.swp
result
