#!/usr/bin/env bash
# Session wrapper for mango, launched by ly via mango.desktop.
#
# Why this exists rather than just Exec=mango:
#
#  1. D-Bus. ly execs the session with no session bus, so anything using one
#     (waybar, swaync, nm-applet, blueman-applet) dies with
#     "Cannot autolaunch D-Bus without X11 $DISPLAY".
#
#  2. Cursor. mango DRAWS the cursor, so it reads XCURSOR_THEME/XCURSOR_SIZE
#     from its OWN environment at startup. `env=` lines in mango's config only
#     export to child processes, which is why waybar and ghostty picked the
#     theme up while the pointer itself stayed the tiny default. mango has no
#     cursor_theme option at all, so setting it here is the only way.
export XCURSOR_THEME=Bibata-Modern-Ice
export XCURSOR_SIZE=32
export XDG_CURRENT_DESKTOP=mango
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=mango

#  3. Logging. ly points the session's stdout at ~/ly-session.log but leaves
#     stderr pointed at /dev/tty2 -- so every warning and every config error
#     mango emits is written straight to a VT that the compositor paints over
#     about a second later. It is visible just long enough to notice and not
#     long enough to read, and it is stored nowhere.
#
#     That cost real time: a bad line in bind.conf silently killed a keybind,
#     and finding out what it said meant recovering the VT's text buffer out
#     of /dev/vcs2 after the fact. Send stderr to a file instead.
#
#     One rotation is kept, matching the .old convention the kernel images in
#     /boot already use, so the previous session survives one relogin -- which
#     is exactly what you want when a session dies and takes its screen away.
LOG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
LOG="$LOG_DIR/mango-session.log"
mkdir -p "$LOG_DIR"
[ -f "$LOG" ] && mv -f "$LOG" "$LOG.old"
{
    echo "─── session start: $(date '+%Y-%m-%d %H:%M:%S') ───"
    echo "─── mango: $(command -v mango) ───"
} > "$LOG"

exec dbus-run-session -- mango "$@" 2>>"$LOG"
