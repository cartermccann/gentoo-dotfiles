xfce-base/exo wayland

# ── seat management (REQUIRED for any wlroots compositor) ──────
# sys-auth/seatd ships libseat, and the base profile builds it with every
# backend off: USE="-builtin -elogind -server -systemd". libseat.so then has
# no way to open a seat, and mango dies at startup with:
#   [libseat] No backend was able to open a seat
#   [backend/backend.c:399] Failed to start a DRM session
# elogind is already running and owns seat0, so the logind backend is the
# right one here — no seatd daemon needed.
sys-auth/seatd elogind

# ── waybar modules ─────────────────────────────────────────────
# The base profile builds waybar with nearly every backend off, which makes
# most of the bar's config silently dead: no tray, no pulseaudio, no network,
# no backlight, no mpris. The modules parse fine and simply never render.
gui-apps/waybar backlight mpris network pipewire pulseaudio tray upower wifi

