{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 6,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    // Left  : clock, then what's playing.
    // Centre: open windows.
    // Right : status, heaviest-to-lightest toward the corner.
    "modules-left": ["clock", "mpris", "idle_inhibitor"],
    "modules-center": ["wlr/taskbar"],
    "modules-right": [
        "privacy",
        "group/system",
        "bluetooth",
        "network",
        "pulseaudio",
        "backlight",
        "battery",
        "custom/swaync",
        "tray",
        "custom/power"
    ],

    "clock": {
        "format": "َ°¥”  {:%a %d %b  %H:%M}",
        "format-alt": "َ°¥”  {:%H:%M:%S}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months":   "<span color='#e7ebf2'><b>{}</b></span>",
                "days":     "<span color='#8b93a4'>{}</span>",
                "weekdays": "<span color='#3b6bff'><b>{}</b></span>",
                "today":    "<span color='#3b6bff'><b><u>{}</u></b></span>"
            }
        },
        "actions": { "on-click-right": "mode", "on-scroll-up": "shift_up", "on-scroll-down": "shift_down" }
    },

    // Music. Requires waybar built with USE=mpris (libplayerctl).
    "mpris": {
        "format": "{status_icon}  {dynamic}",
        "format-paused": "{status_icon}  <i>{dynamic}</i>",
        "status-icons": { "playing": "َ°گٹ", "paused": "َ°ڈ¤", "stopped": "َ°“›" },
        "dynamic-order": ["title", "artist"],
        "dynamic-len": 38,
        "title-len": 30,
        "artist-len": 18,
        "interval": 1,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
        "on-scroll-up": "playerctl position 5+",
        "on-scroll-down": "playerctl position 5-",
        "tooltip-format": "{player} آ· {status}\n{title}\n{artist}\n{album}"
    },

    // Coffee-cup toggle: keeps the screen awake for video or long builds.
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": { "activated": "َ°…¶", "deactivated": "َ°›ٹ" },
        "tooltip-format-activated": "Idle inhibited â€” screen stays awake",
        "tooltip-format-deactivated": "Idle normal"
    },

    // Mic / camera / screenshare in use.
    "privacy": {
        "icon-spacing": 6,
        "icon-size": 13,
        "transition-duration": 220,
        "modules": [
            { "type": "screenshare", "tooltip": true },
            { "type": "audio-in",    "tooltip": true }
        ]
    },

    // Collapsed to a single chip; hover expands the rest.
    "group/system": {
        "orientation": "horizontal",
        "drawer": { "transition-duration": 320, "transition-left-to-right": false },
        "modules": ["cpu", "memory", "temperature", "disk"]
    },

    "cpu":    { "format": "َ°کڑ  {usage}%", "interval": 3, "on-click": "ghostty -e btop" },
    "memory": { "format": "َ°چ›  {percentage}%", "interval": 5, "tooltip-format": "{used:0.1f}G / {total:0.1f}G" },
    "temperature": {
        "interval": 5,
        "critical-threshold": 82,
        "format": "َ°”ڈ  {temperatureC}آ°",
        "format-critical": "َ°”ڈ  {temperatureC}آ°"
    },
    "disk": {
        "interval": 60,
        "format": "َ°‹ٹ  {percentage_used}%",
        "path": "/",
        "tooltip-format": "{used} / {total} on {path}"
    },

    // Real app icons, from the GTK icon theme. Cannot be ordered by workspace
    // (wlr-foreign-toplevel has no concept of tags) â€” order is compositor
    // announce order, i.e. roughly when each window was opened.
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": ["rofi"]
    },


    "tray": { "icon-size": 16, "spacing": 8 },

    // Session actions. Opens the same rofi menu as Super+Shift+Escape, so the
    // pointer and the keyboard reach one implementation.
    "custom/power": {
        "format": "َ°گ¥",
        "tooltip": true,
        "tooltip-format": "Session\nlock \u00b7 logout \u00b7 suspend \u00b7 reboot \u00b7 shutdown",
        // NOTE the `sh -c` wrapper, and keep it on any on-click starting with ~.
        // waybar launches these with Glib::spawn_command_line_async, which splits
        // the string into argv itself and never runs a shell -- so a leading ~ is
        // passed through literally, the path does not exist, and the click does
        // nothing at all. Every other on-click here names a bare command, which
        // is why this and the volume mute binding were the only two that were dead.
        "on-click": "sh -c ~/.config/mango/scripts/powermenu.sh"
    },

    "custom/swaync": {
        "tooltip": true,
        "format": "{icon}",
        "format-icons": {
            "notification": "َ°‚ڑ", "none": "َ°‚œ",
            "dnd-notification": "َ°‚›", "dnd-none": "َ°ھ‘"
        },
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    // One glyph in every state. `format-on` must stay defined even though it is
    // now identical to `format`: leaving it out was a real bug, because with the
    // controller powered but nothing paired waybar fell through to the bare
    // `format` and this became the one chip that rendered differently.
    //
    // State is carried by COLOUR, not words -- #bluetooth.connected goes accent
    // and .off dims, the
    // same way #pulseaudio.muted dims rather than swapping its icon. This is
    // nf-fa-bluetooth, not the Material Design one: MDI only draws bluetooth as
    // a thin stroke rune, which read a full weight lighter than the solid
    // wifi/vol/bri/bat silhouettes either side of it. Rendered side by side to
    // pick it.
    "bluetooth": {
        "format": "ïٹ“",
        "format-on": "ïٹ“",
        "format-off": "ïٹ“",
        "format-disabled": "ïٹ“",
        "format-no-controller": "ïٹ“",
        "format-connected": "ïٹ“  {num_connections}",
        "tooltip-format": "{controller_alias}\n{status}",
        "tooltip-format-connected": "{controller_alias}\n{device_enumerate}",
        "on-click": "blueman-manager"
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "َ°–پ",
        "format-bluetooth": "{icon}  {volume}%",
        "format-icons": { "headphone": "َ°‹‹", "headset": "َ°‹ژ", "default": ["َ°•؟", "َ°–€", "َ°•¾"] },
        "scroll-step": 5,
        "on-click": "pavucontrol",
        // sh -c for the same reason as custom/power above: no shell, no ~ expansion.
        "on-click-right": "sh -c '~/.config/mango/scripts/volume.sh mute'"
    },

    "network": {
        "format-wifi": "َ°¤¨  {signalStrength}%",
        "format-ethernet": "َ°Œ¢",
        "format-disconnected": "َ°¤¯",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
        "interval": 5,
        "on-click": "ghostty -e nmtui"
    },

    "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": ["َ°ƒڑ", "َ°ƒ›", "َ°ƒœ", "َ°ƒ‌", "َ°ƒ‍", "َ°ƒں", "َ°ƒ ", "َ°ƒ،", "َ°ƒ¢"],
        "scroll-step": 5
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon}  {capacity}%",
        "format-charging": "َ°‚„  {capacity}%",
        "format-plugged": "َ°‚€  {capacity}%",
        "tooltip-format": "{timeTo}  ({power:0.1f} W)",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¹"]
    }
}
